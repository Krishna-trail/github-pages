HttpSession session = request.getSession();

Long storedRefTime = (Long) session.getAttribute("storedRefTime");

long expiryDuration = 90 * 1000; // 90 seconds
long currentTime = System.currentTimeMillis();

long remainingSeconds;

if (storedRefTime == null) {
    // First time
    storedRefTime = currentTime;
    session.setAttribute("storedRefTime", storedRefTime);
    remainingSeconds = 90;
} else {
    long elapsedMillis = currentTime - storedRefTime;
    long remainingMillis = expiryDuration - elapsedMillis;

    if (remainingMillis <= 0) {
        // Expired → reset
        storedRefTime = currentTime;
        session.setAttribute("storedRefTime", storedRefTime);
        remainingSeconds = 90;
    } else {
        remainingSeconds = remainingMillis / 1000;
    }
}

request.setAttribute("resumeTime", remainingSeconds);
