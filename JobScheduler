<script>
function goToReceiver() {

    // Read the cookie value from browser
    const cookies = document.cookie;  
    console.log("ALL COOKIES:", cookies);

    // (Optional) extract only destURL cookie
    const destCookie = cookies
        .split("; ")
        .find(row => row.startsWith("destURL="));

    console.log("destURL cookie:", destCookie);

    // Now redirect
    window.location.href = "https://server2211.intranet.barcapint.com/receiver.jsp";
}
</script>
