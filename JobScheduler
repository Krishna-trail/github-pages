import java.io.File;
import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.StandardCopyOption;
import java.util.HashSet;
import java.util.Set;

public class CompareAndMoveFiles {
    public static void main(String[] args) {
        // Set your source folders
        String folder1Path = "C:\\Users\\YourFolder1";  // Change to your folder1 path
        String folder2Path = "C:\\Users\\YourFolder2";  // Change to your folder2 path
        String destinationPath = "C:\\Users\\MatchedFiles"; // Folder for matched files

        File folder1 = new File(folder1Path);
        File folder2 = new File(folder2Path);
        File destinationFolder = new File(destinationPath);

        // Create the destination folder if it does not exist
        if (!destinationFolder.exists()) {
            destinationFolder.mkdir();
        }

        if (folder1.exists() && folder1.isDirectory() && folder2.exists() && folder2.isDirectory()) {
            // Store file names from folder1 in a Set
            Set<String> fileNames = new HashSet<>();
            for (File file : folder1.listFiles()) {
                if (file.isFile()) {
                    fileNames.add(file.getName());
                }
            }

            // Check for matching files in folder2
            for (File file : folder2.listFiles()) {
                if (file.isFile() && fileNames.contains(file.getName())) {
                    try {
                        // Move matching files from both folders to the destination folder
                        Files.move(file.toPath(), new File(destinationPath + "\\" + file.getName()).toPath(), StandardCopyOption.REPLACE_EXISTING);
                        Files.move(new File(folder1Path + "\\" + file.getName()).toPath(), new File(destinationPath + "\\" + file.getName()).toPath(), StandardCopyOption.REPLACE_EXISTING);
                        System.out.println("Moved: " + file.getName());
                    } catch (IOException e) {
                        System.out.println("Error moving file: " + file.getName());
                        e.printStackTrace();
                    }
                }
            }
        } else {
            System.out.println("One or both folders do not exist.");
        }
    }
}
