import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.Mock;
import org.mockito.Mockito;
import org.powermock.api.mockito.PowerMockito;
import org.powermock.core.classloader.annotations.PrepareForTest;
import org.powermock.modules.junit4.PowerMockRunner;

import static org.mockito.Mockito.*;

@RunWith(PowerMockRunner.class)
@PrepareForTest({HexBin.class})
public class RefIdValidatorTest {

    @Mock
    private ArtifactPersistenceService persistenceService;

    @Test(expected = PasswordValidationException.class)
    public void testRefTokenNameIsNull_ThrowsPasswordValidationException() {
        RefIdValidator validator = new RefIdValidator(persistenceService);

        // Simulate input that will cause getValidateInput() to return null
        validator.processPasswordCredential("   ", null);
    }

    @Test(expected = RefIdCredentialException.class)
    public void testRetrieveArtifactFails_ThrowsRefIdCredentialException() throws Exception {
        RefIdValidator validator = new RefIdValidator(persistenceService);

        // Mock static HexBin.stringToBytes
        PowerMockito.mockStatic(HexBin.class);
        PowerMockito.when(HexBin.stringToBytes(anyString())).thenReturn(new byte[]{1, 2, 3});

        // Simulate persistenceService throwing exception
        when(persistenceService.retrieveAndRemoveArtifact(any(byte[].class)))
                .thenThrow(new ArtifactPersistenceServiceException("DB error"));

        validator.processPasswordCredential("validRefId123", null);
    }

    @Test(expected = RefIdCredentialException.class)
    public void testAdapterNotAllowed_ThrowsRefIdCredentialException() throws Exception {
        RefIdValidator validator = new RefIdValidator(persistenceService);

        PowerMockito.mockStatic(HexBin.class);
        PowerMockito.when(HexBin.stringToBytes(anyString())).thenReturn(new byte[]{1, 2, 3});

        ArtifactPersistenceService.Message message = mock(ArtifactPersistenceService.Message.class);
        Map<Object, Object> msg = new HashMap<>();
        msg.put("com.pingidentity.plugin.instanceid", new AttributeValue("wrongAdapter"));
        when(message.getMsg()).thenReturn(msg);

        when(persistenceService.retrieveAndRemoveArtifact(any(byte[].class))).thenReturn(message);

        validator.processPasswordCredential("validRefId123", null);
    }
}
