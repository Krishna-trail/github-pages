package com.example.config;

import java.io.*;
import java.util.Properties;
import javax.servlet.ServletContext;

public class AppConfig {

    private static String privateKey;

    // static block ensures it's loaded once
    public static void load(ServletContext context) {
        if (privateKey != null) return; // already loaded once

        try (InputStream is = context.getResourceAsStream("/WEB-INF/privatekey.txt")) {
            if (is == null) {
                throw new FileNotFoundException("privatekey.txt not found under /WEB-INF/");
            }

            Properties props = new Properties();
            props.load(is);
            privateKey = props.getProperty("KEY");

            System.out.println("Private key loaded: " + privateKey);

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    public static String getPrivateKey() {
        return privateKey;
    }
}
