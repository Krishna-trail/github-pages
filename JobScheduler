import com.google.gson.*;
import org.springframework.http.ResponseEntity;

public class JobSchedulerResponseHandler {

    private final Gson gson = new Gson();

    public void handleResponse(ResponseEntity<String> responseEntity) {
        int statusCode = responseEntity.getStatusCodeValue();
        String body = responseEntity.getBody();

        if (statusCode == 200) {
            handleSuccessResponse(body);
        } else if (statusCode >= 400) {
            handleErrorResponse(body);
        } else {
            System.out.println("Unhandled status: " + statusCode);
        }
    }

    private void handleSuccessResponse(String body) {
        JsonObject json = JsonParser.parseString(body).getAsJsonObject();
        JsonObject data = json.getAsJsonObject("data");
        if (data != null) {
            JsonObject attributes = data.getAsJsonObject("attributes");
            if (attributes != null) {
                String accessToken = attributes.get("accessToken").getAsString();
                String validUpto = attributes.get("accessTokenValidUpto").getAsString();
                System.out.println("Access Token: " + accessToken);
                System.out.println("Valid Upto: " + validUpto);
            }
        }
    }

    private void handleErrorResponse(String body) {
        JsonObject json = JsonParser.parseString(body).getAsJsonObject();
        JsonArray errors = json.getAsJsonArray("errors");

        if (errors != null && errors.size() > 0) {
            for (JsonElement errorElement : errors) {
                JsonObject error = errorElement.getAsJsonObject();
                String title = error.has("title") ? error.get("title").getAsString() : "No title";
                System.out.println("Error Title: " + title);
            }
        } else {
            System.out.println("Unknown error occurred");
        }
    }
}
