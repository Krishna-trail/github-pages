import org.json.JSONArray;
import org.json.JSONObject;

public class ErrorResponseParser {
    public static void main(String[] args) {
        String responseBody = "400:{\"errors\":[{\"id\":\"6e09273b\", \"code\": \"BAD REQUEST\", \"title\": \"Unable to process the request\", \"detail\":\"Salesforce User Id is not allowed for requested TIAA-AS account: sysTIA\"}]}";

        // Split on the first colon to separate status and JSON
        String[] parts = responseBody.split(":", 2);
        if (parts.length == 2) {
            String jsonString = parts[1].trim();

            JSONObject json = new JSONObject(jsonString);
            if (json.has("errors")) {
                JSONArray errors = json.getJSONArray("errors");
                for (int i = 0; i < errors.length(); i++) {
                    JSONObject error = errors.getJSONObject(i);
                    if (error.has("detail")) {
                        String detail = error.getString("detail");
                        System.out.println("Error Detail: " + detail);
                    }
                }
            } else {
                System.out.println("No errors found.");
            }
        } else {
            System.out.println("Invalid response format.");
        }
    }
}
