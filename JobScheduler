import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.*;

@ExtendWith(MockitoExtension.class)
class MyServiceTest {

    @Mock
    private AttrMap attrMap;

    @Mock
    private AttrValue attrValue; // class returned by attrMap.get(...)

    private MyService myService = new MyService();

    @Test
    void testKeyMissing_WhenKeyNotPresent() {
        when(attrMap.containsKey(MyService.CLIENTID)).thenReturn(false);

        boolean result = myService.keyMissing(attrMap);

        assertTrue(result);
    }

    @Test
    void testKeyMissing_WhenValueIsEmpty() {
        when(attrMap.containsKey(MyService.CLIENTID)).thenReturn(true);
        when(attrMap.get(MyService.ID)).thenReturn(attrValue);
        when(attrValue.getValue()).thenReturn("");

        boolean result = myService.keyMissing(attrMap);

        assertTrue(result);
    }

    @Test
    void testKeyMissing_WhenValueIsNotEmpty() {
        when(attrMap.containsKey(MyService.CLIENTID)).thenReturn(true);
        when(attrMap.get(MyService.ID)).thenReturn(attrValue);
        when(attrValue.getValue()).thenReturn("abc");

        boolean result = myService.keyMissing(attrMap);

        assertFalse(result);
    }
}
