import static org.mockito.Mockito.*;
import static org.junit.Assert.*;

import java.util.HashMap;
import java.util.Map;

import org.junit.Before;
import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.*;
import org.mockito.junit.MockitoJUnitRunner;

@RunWith(MockitoJUnitRunner.class)
public class PasswordCredentialProcessorTest {

    @Mock
    private ArtifactPersistenceService persistenceService;

    @InjectMocks
    private PasswordCredentialProcessor processor; // class where method is defined

    private static final String VALID_USERNAME = "testUser";
    private static final String VALID_REFID = "ref123";

    @Before
    public void setup() {
        // Stub static factory call
        StateMgmtFactory.setArtifactPersistenceService(persistenceService);
    }

    @Test(expected = PasswordValidationException.class)
    public void testNullUsernameThrowsException() throws Exception {
        processor.processPasswordCredential(null, VALID_REFID);
    }

    @Test(expected = PasswordValidationException.class)
    public void testEmptyRefIdThrowsException() throws Exception {
        processor.processPasswordCredential(VALID_USERNAME, "");
    }

    @Test(expected = UsernameRecoveryException.class)
    public void testInvalidUsernameThrowsException() throws Exception {
        // assume regex requires only digits → stub Encode.forJava
        processor.processPasswordCredential("invalid-username!", VALID_REFID);
    }

    @Test(expected = PasswordValidationException.class)
    public void testInvalidRefIdThrowsException() throws Exception {
        // return null from validate input
        processor.processPasswordCredential(VALID_USERNAME, "###");
    }

    @Test(expected = RefIdCredentialException.class)
    public void testNullMessageFromPersistenceThrowsException() throws Exception {
        byte[] refBytes = new byte[]{1,2,3};
        when(persistenceService.retrieveAndRemoveArtifact(any())).thenReturn(null);

        processor.processPasswordCredential(VALID_USERNAME, VALID_REFID);
    }

    @Test
    public void testValidCaseReturnsAttributeMap() throws Exception {
        // Mock message
        Map<Object,Object> attri = new HashMap<>();
        attri.put("key1", new AttributeValue("value1"));
        attri.put("com.pingidentity.plugin.instanceid", new AttributeValue("adapter1"));

        ArtifactPersistenceService.Message message = mock(ArtifactPersistenceService.Message.class);
        when(message.getMsg()).thenReturn(attri);
        when(persistenceService.retrieveAndRemoveArtifact(any())).thenReturn(message);

        AttributeMap result = processor.processPasswordCredential(VALID_USERNAME, VALID_REFID);

        assertNotNull(result);
        assertEquals("value1", result.get("key1"));
    }
}
