import java.time.Instant;
import java.time.ZoneId;
import java.time.format.DateTimeFormatter;

public class ADTimeConverter {
    public static void main(String[] args) {
        try {
            String timestampStr = "134015544055726467"; // your AD lastLogonTimeStamp
            timestampStr = timestampStr.trim(); // clean whitespace

            long fileTime = Long.parseLong(timestampStr);

            // Windows epoch (1601-01-01) to Unix epoch (1970-01-01)
            long windowsToUnixEpochDiff = 116444736000000000L;

            // Convert to milliseconds
            long millis = (fileTime - windowsToUnixEpochDiff) / 10000;

            // Format to system timezone
            Instant instant = Instant.ofEpochMilli(millis);
            String formatted = DateTimeFormatter.ofPattern("MMM dd, yyyy HH:mm:ss")
                                                .withZone(ZoneId.systemDefault())
                                                .format(instant);

            System.out.println("Converted Time: " + formatted);
        } catch (NumberFormatException e) {
            System.err.println("Invalid timestamp string! Value must be numeric.");
        }
    }
}
