import static org.mockito.Mockito.*;
import static org.junit.Assert.*;

import java.util.HashMap;
import java.util.Map;

import org.junit.Before;
import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.Mock;
import org.powermock.api.mockito.PowerMockito;
import org.powermock.core.classloader.annotations.PowerMockIgnore;
import org.powermock.core.classloader.annotations.PrepareForTest;
import org.powermock.modules.junit4.PowerMockRunner;

@RunWith(PowerMockRunner.class)
@PrepareForTest({ StateMgmtFactory.class, Encode.class }) // classes with static methods
@PowerMockIgnore({"javax.crypto.*", "javax.net.ssl.*"})   // avoid classloader issues
public class PasswordCredentialProcessorTest {

    @Mock
    private ArtifactPersistenceService persistenceService;

    private PasswordCredentialProcessor processor;

    private static final String VALID_USERNAME = "testUser";
    private static final String VALID_REFID = "ref123";

    @Before
    public void setup() {
        processor = new PasswordCredentialProcessor();

        // Mock static methods
        PowerMockito.mockStatic(StateMgmtFactory.class);
        PowerMockito.mockStatic(Encode.class);

        when(StateMgmtFactory.getArtifactPersistenceService())
            .thenReturn(persistenceService);

        // Default encode mock just returns the same string
        when(Encode.forJava(anyString())).thenAnswer(inv -> inv.getArguments()[0]);
    }

    @Test
    public void testNullUsernameReturnsNull() throws Exception {
        AttributeMap result = processor.processPasswordCredential(null, VALID_REFID);
        assertNull(result); // because method catches exception and returns null
    }

    @Test
    public void testEmptyRefIdReturnsNull() throws Exception {
        AttributeMap result = processor.processPasswordCredential(VALID_USERNAME, "");
        assertNull(result);
    }

    @Test
    public void testInvalidUsernameReturnsNull() throws Exception {
        when(Encode.forJava("invalid-username!")).thenReturn("invalid-username!");
        AttributeMap result = processor.processPasswordCredential("invalid-username!", VALID_REFID);
        assertNull(result);
    }

    @Test
    public void testInvalidRefIdReturnsNull() throws Exception {
        AttributeMap result = processor.processPasswordCredential(VALID_USERNAME, "###");
        assertNull(result);
    }

    @Test
    public void testNullMessageFromPersistenceReturnsNull() throws Exception {
        when(persistenceService.retrieveAndRemoveArtifact(any())).thenReturn(null);
        AttributeMap result = processor.processPasswordCredential(VALID_USERNAME, VALID_REFID);
        assertNull(result);
    }

    @Test
    public void testValidCaseReturnsAttributeMap() throws Exception {
        // Mock persistence service return
        Map<Object,Object> attri = new HashMap<>();
        attri.put("key1", new AttributeValue("value1"));
        attri.put("com.pingidentity.plugin.instanceid", new AttributeValue("adapter1"));

        ArtifactPersistenceService.Message message = mock(ArtifactPersistenceService.Message.class);
        when(message.getMsg()).thenReturn(attri);

        when(persistenceService.retrieveAndRemoveArtifact(any())).thenReturn(message);

        AttributeMap result = processor.processPasswordCredential(VALID_USERNAME, VALID_REFID);

        assertNotNull(result);
        assertEquals("value1", result.get("key1"));
    }
}
