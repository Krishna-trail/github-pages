import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.Mockito;
import org.mockito.junit.MockitoJUnitRunner;

import static org.mockito.Mockito.*;
import static org.junit.Assert.*;

// JUnit 4 + Mockito runner
@RunWith(MockitoJUnitRunner.class)
public class RefIdCredentialValidatorTest {

    @InjectMocks
    private RefIdCredentialValidator validator; // real class under test

    @Mock
    private ArtifactPersistenceService mockPersistenceService; // dependency

    // ---------- Test 1: Invalid RefID (refTokenName = null) ----------
    @Test(expected = PasswordValidationException.class)
    public void testInvalidRefIdThrowsPasswordValidationException() throws Exception {
        // Arrange
        String username = "testuser";
        String refId = " "; // will cause getValidateInput → null

        // Stub getValidateInput to return null
        RefIdCredentialValidator spyValidator = Mockito.spy(validator);
        doReturn(null).when(spyValidator).getValidateInput(anyString(), anyString());

        // Act
        spyValidator.processPasswordCredential(username, refId);
    }

    // ---------- Test 2: PersistenceService throws exception ----------
    @Test(expected = RefIdCredentialException.class)
    public void testPersistenceServiceFailureThrowsRefIdCredentialException() throws Exception {
        // Arrange
        String username = "testuser";
        String refId = "validref";

        RefIdCredentialValidator spyValidator = Mockito.spy(validator);
        doReturn("validref").when(spyValidator).getValidateInput(anyString(), anyString());

        byte[] bytes = "validref".getBytes();
        when(mockPersistenceService.retrieveAndRemoveArtifact(bytes))
                .thenThrow(new ArtifactPersistenceServiceException("Service failure"));

        // Act
        spyValidator.processPasswordCredential(username, refId);
    }

    // ---------- Test 3: Happy Path ----------
    @Test
    public void testValidFlowSuccess() throws Exception {
        // Arrange
        String username = "testuser";
        String refId = "validref";

        RefIdCredentialValidator spyValidator = Mockito.spy(validator);
        doReturn("validref").when(spyValidator).getValidateInput(anyString(), anyString());

        byte[] bytes = "validref".getBytes();
        ArtifactPersistenceService.Message mockMessage = mock(ArtifactPersistenceService.Message.class);
        when(mockPersistenceService.retrieveAndRemoveArtifact(bytes)).thenReturn(mockMessage);

        // Act
        spyValidator.processPasswordCredential(username, refId);

        // Assert → verify persistenceService was called
        verify(mockPersistenceService, times(1)).retrieveAndRemoveArtifact(bytes);
    }
}
