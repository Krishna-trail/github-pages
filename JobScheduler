<!DOCTYPE html>
<html>
<head>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
</head>

<body>

<div id="qrBox" style="width:220px;height:220px;position:relative;"></div>

<script>
    // 1️⃣ Generate QR code
    var qr = new QRCode(document.getElementById("qrBox"), {
        text: "https://your-company-url.com",
        width: 220,
        height: 220,
        correctLevel: QRCode.CorrectLevel.H  // Higher error correction for logo
    });

    // 2️⃣ Draw logo at center
    setTimeout(function () {
        var canvas = document.querySelector("#qrBox canvas");
        var ctx = canvas.getContext("2d");

        var logo = new Image();
        logo.src = "your-logo.png";   // ⭐ Put your company logo here

        logo.onload = function () {
            let size = 60; // logo size
            let x = (canvas.width - size) / 2;
            let y = (canvas.height - size) / 2;

            // Optional white background behind logo (clean look)
            ctx.fillStyle = "white";
            ctx.fillRect(x, y, size, size);

            ctx.drawImage(logo, x, y, size, size);
        };
    }, 300);
</script>

</body>
</html>
