import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;

import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.*;

class MyServiceTest {

    @Mock
    private Configuration config;

    @InjectMocks
    private MyService myService;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
    }

    @Test
    void testConfigure_SetsValuesCorrectly() {
        // Arrange
        when(config.getFieldValue(MyService.ALLOWED)).thenReturn("YES");
        when(config.getFieldValue(MyService.EXCEPTION)).thenReturn("NO");

        // Act
        myService.configure(config);

        // Assert
        assertEquals("YES", myService.getAllowed());
        assertEquals("NO", myService.getException());

        // Verify interactions
        verify(config).getFieldValue(MyService.ALLOWED);
        verify(config).getFieldValue(MyService.EXCEPTION);
    }
}
