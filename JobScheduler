public class TokenManager {

    private static String accessToken = null;
    private static long tokenExpiryTimeMillis = 0;

    public static String getAccessToken() {
        if (accessToken != null && !isTokenExpired()) {
            return accessToken;
        }

        // Token is null or expired, call token API
        fetchNewTokenFromApi();
        return accessToken;
    }

    private static boolean isTokenExpired() {
        return System.currentTimeMillis() >= tokenExpiryTimeMillis;
    }

    private static void fetchNewTokenFromApi() {
        try {
            // Send request (use your actual request object and URL)
            ResponseEntity<String> response = restTemplate.postForEntity("https://api.example.com/token", request, String.class);

            if (response.getStatusCode() == HttpStatus.OK) {
                ObjectMapper objectMapper = new ObjectMapper();
                JsonNode json = objectMapper.readTree(response.getBody());

                JsonNode tokenNode = json.get("access_token");
                JsonNode expiresInNode = json.get("expires_in");

                if (tokenNode != null && !tokenNode.isNull() && expiresInNode != null && !expiresInNode.isNull()) {
                    accessToken = tokenNode.asText();
                    long expiresInSeconds = expiresInNode.asLong();
                    tokenExpiryTimeMillis = System.currentTimeMillis() + (expiresInSeconds * 1000);
                    return;
                } else {
                    LOG.error("Missing access_token or expires_in in response: " + response.getBody());
                }
            } else {
                LOG.error("Failed to get token: " + response.getStatusCode() + " " + response.getBody());
            }
        } catch (Exception e) {
            LOG.error("Error while fetching token: " + e.getMessage(), e);
        }

        // In case of failure, clear the token to force refresh next time
        accessToken = null;
        tokenExpiryTimeMillis = 0;
    }
}
