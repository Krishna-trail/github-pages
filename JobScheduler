<!DOCTYPE html>
<html>
<body>

<div id="qrcode" style="position: relative; width: 200px; height: 200px;"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<script>
    // 1️⃣ Generate QR code
    var qrDiv = document.getElementById("qrcode");
    var qr = new QRCode(qrDiv, {
        text: "https://your-company-link.com",
        width: 200,
        height: 200,
        correctLevel: QRCode.CorrectLevel.H // important for logo
    });

    // 2️⃣ After QR code loads, draw logo on top
    setTimeout(() => {
        let qrCanvas = qrDiv.querySelector("canvas");

        let ctx = qrCanvas.getContext("2d");
        let logo = new Image();
        logo.src = "logo.png";  // <-- your logo path

        logo.onload = function () {
            let size = 50; // logo size in center
            let x = (qrCanvas.width - size) / 2;
            let y = (qrCanvas.height - size) / 2;
            ctx.fillStyle = "white"; 
            ctx.fillRect(x, y, size, size);
            ctx.drawImage(logo, x, y, size, size);
        };
    }, 500);
</script>

</body>
</html>
