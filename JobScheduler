@ExtendWith(MockitoExtension.class)
public class AuthServiceTest {

    @Mock
    private RestTemplate restTemplate;

    private AuthService authService;
    private final String tokenUrl = "http://example.com/token";

    @BeforeEach
    void setUp() {
        authService = new AuthService(restTemplate, tokenUrl);
    }

    @Test
    void testGetToken_success() {
        // Arrange
        String username = "testuser";
        String password = "testpass";
        String expectedToken = "mocked-token";

        HttpHeaders headers = new HttpHeaders();
        headers.setContentType(MediaType.APPLICATION_JSON);

        Map<String, String> body = new HashMap<>();
        body.put("username", username);
        body.put("password", password);

        HttpEntity<Map<String, String>> entity = new HttpEntity<>(body, headers);
        ResponseEntity<String> mockResponse = new ResponseEntity<>(expectedToken, HttpStatus.OK);

        when(restTemplate.exchange(
                eq(tokenUrl),
                eq(HttpMethod.POST),
                any(HttpEntity.class),
                eq(String.class)
        )).thenReturn(mockResponse);

        // Act
        String actualToken = authService.getToken(username, password);

        // Assert
        assertEquals(expectedToken, actualToken);
        verify(restTemplate, times(1))
            .exchange(eq(tokenUrl), eq(HttpMethod.POST), any(HttpEntity.class), eq(String.class));
    }
}
