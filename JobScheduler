import java.time.Instant;
import java.time.LocalDateTime;
import java.time.ZoneId;
import java.time.format.DateTimeFormatter;

public class ADTimeConverter {
    public static void main(String[] args) {
        // Example AD lastLogonTimestamp (replace with yours)
        String adTimestampStr = "133622275440000000";  // string from AD
        long adTimestamp = Long.parseLong(adTimestampStr);

        // Convert Windows FILETIME → Unix epoch millis
        long unixMillis = (adTimestamp / 10000L) - 11644473600000L;

        // Convert to LocalDateTime based on system timezone
        LocalDateTime dateTime = Instant.ofEpochMilli(unixMillis)
                .atZone(ZoneId.systemDefault())
                .toLocalDateTime();

        // Format output
        DateTimeFormatter formatter = DateTimeFormatter.ofPattern("MMM dd, yyyy HH:mm:ss");
        String formatted = dateTime.format(formatter);

        System.out.println(formatted); // Sep 11, 2025 17:32:24
    }
}
