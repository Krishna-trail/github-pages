<!DOCTYPE html>
<html>
<head>
  <title>Custom QR Code with Styled Corners</title>
</head>
<body>
<canvas id="qrCanvas"></canvas>
<img id="logo" src="logo.png" style="display:none;"/>

<script src="https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.js"></script>
<script>
function drawStyledQRCode(text) {
    const qr = qrcode(4, 'M'); // Version 4, Medium error correction
    qr.addData(text);
    qr.make();

    const canvas = document.getElementById('qrCanvas');
    const ctx = canvas.getContext('2d');

    const moduleCount = qr.getModuleCount();
    const size = 300; // canvas size
    const moduleSize = size / moduleCount;
    canvas.width = size;
    canvas.height = size;

    // Draw white background
    ctx.fillStyle = "#FFFFFF";
    ctx.fillRect(0, 0, size, size);

    // Draw QR modules except corner squares
    for (let row = 0; row < moduleCount; row++) {
        for (let col = 0; col < moduleCount; col++) {
            if (qr.isDark(row, col)) {
                const inTopLeftCorner = row < 7 && col < 7;
                const inTopRightCorner = row < 7 && col >= moduleCount - 7;
                const inBottomLeftCorner = row >= moduleCount - 7 && col < 7;

                if (!inTopLeftCorner && !inTopRightCorner && !inBottomLeftCorner) {
                    ctx.fillStyle = "#000000"; // black QR modules
                    ctx.fillRect(col * moduleSize, row * moduleSize, moduleSize, moduleSize);
                }
            }
        }
    }

    // Function to draw styled corner (nested squares)
    function drawCorner(x, y) {
        const outerSize = 7 * moduleSize;
        const innerSize = 3 * moduleSize;
        const offset = moduleSize * 2;

        // Outer square
        ctx.fillStyle = "#0000FF";
        ctx.fillRect(x, y, outerSize, outerSize);

        // White inner square
        ctx.fillStyle = "#FFFFFF";
        ctx.fillRect(x + moduleSize, y + moduleSize, outerSize - 2 * moduleSize, outerSize - 2 * moduleSize);

        // Inner blue square
        ctx.fillStyle = "#0000FF";
        ctx.fillRect(x + offset, y + offset, innerSize, innerSize);
    }

    // Draw three corners
    drawCorner(0, 0); // top-left
    drawCorner(size - 7 * moduleSize, 0); // top-right
    drawCorner(0, size - 7 * moduleSize); // bottom-left

    // Draw white center for logo
    const logo = document.getElementById('logo');
    logo.onload = function() {
        const logoSize = size * 0.25; // logo occupies 25% of QR
        const center = size / 2;
        ctx.fillStyle = "#FFFFFF";
        ctx.fillRect(center - logoSize/2, center - logoSize/2, logoSize, logoSize);

        // Draw logo
        ctx.drawImage(logo, center - logoSize/2, center - logoSize/2, logoSize, logoSize);
    }
    logo.src = "logo.png"; // your logo path
}

// Generate QR
drawStyledQRCode("https://your-url.com");
</script>
</body>
</html>
