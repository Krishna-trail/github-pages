@ExtendWith(MockitoExtension.class)
public class AuthServiceTest {

    @InjectMocks
    private AuthService authService; // class containing getToken()

    @Mock
    private RestTemplate restTemplate;

    @BeforeEach
    void setUp() {
        ReflectionTestUtils.setField(authService, "tokenUrl", "https://dummy-token-url");
        ReflectionTestUtils.setField(authService, "username", "testuser");
        ReflectionTestUtils.setField(authService, "password", "testpass");
    }

    @Test
    void testGetTokenSuccess() {
        String expectedToken = "dummy-token";

        // Mocking response
        ResponseEntity<String> responseEntity = new ResponseEntity<>(expectedToken, HttpStatus.OK);

        // Capture the actual HttpEntity
        ArgumentCaptor<HttpEntity> captor = ArgumentCaptor.forClass(HttpEntity.class);
        when(restTemplate.postForEntity(eq("https://dummy-token-url"), captor.capture(), eq(String.class)))
            .thenReturn(responseEntity);

        String actualToken = authService.getToken();

        assertEquals(expectedToken, actualToken);

        // You can also assert request body or headers
        HttpEntity<Map<String, String>> capturedEntity = captor.getValue();
        assertNotNull(capturedEntity.getBody());
        assertEquals("testuser", capturedEntity.getBody().get("username"));
        assertEquals("testpass", capturedEntity.getBody().get("password"));
    }
}
