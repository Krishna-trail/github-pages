try {
    int statusCode = response.getStatusCodeValue();
    String responseBody = response.getBody();

    logger.log(Level.INFO, "Received status code: ******* " + statusCode);
    logger.log(Level.INFO, "Received response body: ======= " + responseBody);

    if (responseBody != null && responseBody.trim().startsWith("{")) {
        ObjectMapper mapper = new ObjectMapper();
        JsonNode root = mapper.readTree(responseBody);

        if (!String.valueOf(statusCode).startsWith("2")) {
            JsonNode errorsNode = root.path("errors");
            if (errorsNode.isArray() && errorsNode.size() > 0) {
                JsonNode error = errorsNode.get(0);
                String title = error.path("title").asText("");
                String detail = error.path("detail").asText("");

                System.out.println("Detail: " + detail);

                if (statusCode == 401 && !detail.isEmpty()) {
                    if (detail.contains(Constants.UNAUTHORIZED)) {
                        if (detail.contains(Constants.TIAA_INVALID_TOKEN)) {
                            logger.log(Level.INFO, "Signature Expired. JWT is no longer valid.");
                            // Handle token expiration logic here
                        }
                    }
                }
            }
        } else {
            // Handle success response here
            String token = root.path("token").asText("");
            String type = root.path("type").asText("");
            String expires = root.path("expires").asText("");

            logger.log(Level.INFO, "Mock Token: " + token);
            logger.log(Level.INFO, "Mock Type: " + type);
            logger.log(Level.INFO, "Mock Expires: " + expires);
        }

    } else {
        throw new RuntimeException("Invalid JSON response: " + responseBody);
    }

} catch (Exception e) {
    logger.log(Level.SEVERE, "Exception while processing response", e);
}
