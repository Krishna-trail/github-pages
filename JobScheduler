import java.time.Instant;
import java.time.ZoneId;
import java.time.format.DateTimeFormatter;

public class ADTimeConverter {
    public static void main(String[] args) {
        long fileTime = 134015544055726467L;

        // Windows epoch starts at 1601-01-01, Unix epoch at 1970-01-01
        long windowsToUnixEpochDiff = 116444736000000000L;

        // Convert to milliseconds
        long millis = (fileTime - windowsToUnixEpochDiff) / 10000;

        // Format to desired style
        Instant instant = Instant.ofEpochMilli(millis);
        String formatted = DateTimeFormatter.ofPattern("MMM dd, yyyy HH:mm:ss")
                                            .withZone(ZoneId.systemDefault())
                                            .format(instant);

        System.out.println("Converted Time: " + formatted);
    }
}
