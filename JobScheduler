import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.lang.reflect.Field;

import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.*;

@ExtendWith(MockitoExtension.class)
class MyServiceTest {

    @Mock
    private Configuration config;

    @Test
    void testConfigureSetsPrivateFields() throws Exception {
        // Arrange
        MyService service = new MyService();
        when(config.getFieldValue("List of allowed")).thenReturn("ALLOW123");
        when(config.getFieldValue("List of Exception IDs")).thenReturn("EXC999");

        // Act
        service.configure(config);

        // Assert private field "allowed"
        Field allowedField = MyService.class.getDeclaredField("allowed");
        allowedField.setAccessible(true);
        String allowedValue = (String) allowedField.get(service);
        assertEquals("ALLOW123", allowedValue);

        // Assert private field "exceptionIds"
        Field exceptionField = MyService.class.getDeclaredField("exceptionIds");
        exceptionField.setAccessible(true);
        String exceptionValue = (String) exceptionField.get(service);
        assertEquals("EXC999", exceptionValue);

        // Verify interactions with mock
        verify(config).getFieldValue("List of allowed");
        verify(config).getFieldValue("List of Exception IDs");
    }
}
