import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;
import java.util.Map;

public class UserServiceTest {

    @Test
    void testSaveUser_ValidInputs() {
        UserService service = new UserService();
        Map<String, String> result = service.saveUser("john", "1234");

        assertNotNull(result);
        assertEquals(1, result.size());
        assertTrue(result.containsKey("john"));
        assertEquals("1234", result.get("john"));
    }

    @Test
    void testSaveUser_NullUsername() {
        UserService service = new UserService();
        Map<String, String> result = service.saveUser(null, "1234");

        assertNotNull(result);
        assertTrue(result.isEmpty());
    }

    @Test
    void testSaveUser_NullPassword() {
        UserService service = new UserService();
        Map<String, String> result = service.saveUser("john", null);

        assertNotNull(result);
        assertTrue(result.isEmpty());
    }

    @Test
    void testSaveUser_BothNull() {
        UserService service = new UserService();
        Map<String, String> result = service.saveUser(null, null);

        assertNotNull(result);
        assertTrue(result.isEmpty());
    }
}
