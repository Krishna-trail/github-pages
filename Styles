.wrapper {
    display: flex;
    justify-content: center;   /* centers both boxes as a group */
    align-items: center;
    gap: 40px;                 /* space between left & right */
    margin-top: 100px;
}

.box {
    width: 250px;
    height: 150px;
    background: #eaeaea;
    border-radius: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
}
